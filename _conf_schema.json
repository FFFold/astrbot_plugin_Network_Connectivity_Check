{
  "targets": {
    "description": "要监测的网络目标列表",
    "type": "list",
    "hint": "配置需要监测的网络目标，每个目标可独立设置检测方式和通知策略",
    "default": [
      {
        "name": "Google",
        "url": "https://www.google.com",
        "method": "http",
        "interval": 300,
        "timeout": 10,
        "retry": 3,
        "notify_on_success": false,
        "notify_on_failure": true,
        "consecutive_failures": 2
      }
    ],
    "items": {
      "name": {
        "description": "目标名称",
        "type": "string",
        "hint": "用于标识这个监测目标，如 Google、百度等"
      },
      "url": {
        "description": "目标地址",
        "type": "string",
        "hint": "要检测的网址或IP，如 https://www.google.com 或 8.8.8.8"
      },
      "method": {
        "description": "检测方式",
        "type": "string",
        "hint": "http: HTTP请求检测; ping: ICMP ping检测; tcp: TCP端口连接检测",
        "options": ["http", "ping", "tcp"],
        "default": "http"
      },
      "interval": {
        "description": "检测间隔(秒)",
        "type": "int",
        "hint": "两次检测之间的间隔时间，建议不少于60秒",
        "default": 300
      },
      "timeout": {
        "description": "超时时间(秒)",
        "type": "int",
        "hint": "单次检测的最大等待时间",
        "default": 10
      },
      "retry": {
        "description": "失败重试次数",
        "type": "int",
        "hint": "检测失败时的重试次数，设为0则不重试",
        "default": 3
      },
      "notify_on_success": {
        "description": "连通时是否通知",
        "type": "bool",
        "hint": "开启后每次检测成功都会发送通知（建议关闭，避免刷屏）",
        "default": false
      },
      "notify_on_failure": {
        "description": "失败时是否通知",
        "type": "bool",
        "hint": "开启后检测失败时发送通知",
        "default": true
      },
      "consecutive_failures": {
        "description": "连续失败几次才报警",
        "type": "int",
        "hint": "避免偶发性网络波动导致误报",
        "default": 2
      }
    }
  },
  "notify_targets": {
    "description": "通知目标列表",
    "type": "list",
    "hint": "检测结果通知给哪些用户或群组。在群里发送 /netcheck 会自动记录该群的UMO",
    "default": [],
    "items": {
      "umo": {
        "description": "统一消息来源标识(UMO)",
        "type": "string",
        "hint": "统一消息来源标识，如 aiocqhttp:GroupMessage:123456 或 aiocqhttp:FriendMessage:123456"
      },
      "description": {
        "description": "描述",
        "type": "string",
        "hint": "用于标识这个通知目标"
      }
    }
  },
  "global_settings": {
    "description": "全局设置",
    "type": "object",
    "hint": "插件的全局配置选项",
    "items": {
      "silent_hours_start": {
        "description": "免打扰开始时间(小时)",
        "type": "int",
        "hint": "夜间免打扰时段开始时间，0-23，设为-1关闭",
        "default": -1
      },
      "silent_hours_end": {
        "description": "免打扰结束时间(小时)",
        "type": "int",
        "hint": "夜间免打扰时段结束时间，0-23",
        "default": 7
      },
      "max_history": {
        "description": "历史记录保留数",
        "type": "int",
        "hint": "每个目标保留的最近检测记录数量",
        "default": 100
      }
    }
  }
}
